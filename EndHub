-- Funções Utilitárias
local function CreateRoundedFrame(parent, size, position, color, transparency, cornerRadius)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = size
    frame.Position = position
    frame.BackgroundColor3 = color
    frame.BackgroundTransparency = transparency
    frame.BorderSizePixel = 0
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = cornerRadius or UDim.new(0, 8)
    corner.Parent = frame
    
    return frame
end

local function CreateShadow(parent, size, position)
    local shadow = Instance.new("ImageLabel")
    shadow.Parent = parent
    shadow.Size = size
    shadow.Position = position
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://1316045217"
    shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
    shadow.ImageTransparency = 0.6
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(10, 10, 10, 10)
    
    return shadow
end

local function TweenObject(object, properties, duration, style, direction)
    local tween = TweenService:Create(object, TweenInfo.new(duration or Config.Animations.Duration, 
        style or Config.Animations.EasingStyle, 
        direction or Config.Animations.EasingDirection), properties)
    tween:Play()
    return tween
end

-- Classe do Botão Flutuante
local FloatingButton = {}
FloatingButton.__index = FloatingButton

function FloatingButton.new(parent, onToggle)
    local self = setmetatable({}, FloatingButton)
    
    local size = 50
    local screenSize = parent.AbsoluteSize
    
    self.Frame = CreateRoundedFrame(parent, UDim2.new(0, size, 0, size), 
        UDim2.new(0, 20, 0, screenSize.Y - size - 20), 
        Config.Theme.Primary, 0, UDim.new(0, size/2))
    
    -- Ícone
    self.Icon = Instance.new("ImageLabel")
    self.Icon.Parent = self.Frame
    self.Icon.Size = UDim2.new(0, 24, 0, 24)
    self.Icon.Position = UDim2.new(0.5, -12, 0.5, -12)
    self.Icon.BackgroundTransparency = 1
    self.Icon.Image = "rbxassetid://6031093046"
    self.Icon.ImageColor3 = Color3.fromRGB(255, 255, 255)
    
    -- Sombra
    CreateShadow(self.Frame, UDim2.new(1, 10, 1, 10), UDim2.new(-0.5, -5, -0.5, -5))
    
    -- Variáveis de arrasto
    self.Dragging = false
    self.DragStart = nil
    self.StartPos = nil
    
    self.Frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = true
            self.DragStart = input.Position
            self.StartPos = self.Frame.Position
        end
    end)
    
    self.Frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = false
        end
    end)
    
    self.Frame.InputChanged:Connect(function(input)
        if self.Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - self.DragStart
            local newPos = UDim2.new(self.StartPos.X.Scale, self.StartPos.X.Offset + delta.X, 
                self.StartPos.Y.Scale, self.StartPos.Y.Offset + delta.Y)
            
            -- Limites da tela
            newPos = UDim2.new(0, math.clamp(newPos.X.Offset, 0, screenSize.X - size), 
                0, math.clamp(newPos.Y.Offset, 0, screenSize.Y - size))
            
            self.Frame.Position = newPos
        end
    end)
    
    self.Frame.MouseButton1Click:Connect(function()
        TweenObject(self.Frame, {BackgroundColor3 = Config.Theme.PrimaryHover}, 0.1)
        TweenObject(self.Frame, {BackgroundColor3 = Config.Theme.Primary}, 0.1, nil, nil, 0.1)
        onToggle()
    end)
    
    return self
end

