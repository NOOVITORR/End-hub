function Menu:CreateToggle(tab, text, default, callback)
    local yPos = 10 + (#tab.Elements * 70)
    local frame = CreateRoundedFrame(tab.Content, UDim2.new(1, 0, 0, 50), 
        UDim2.new(0, 0, 0, yPos), Config.Theme.Surface, 0, UDim.new(0, 8))
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(1, -20, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Config.Theme.Text
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local toggleBg = CreateRoundedFrame(frame, UDim2.new(0, 50, 0, 26), 
        UDim2.new(1, -60, 0.5, -13), Config.Theme.Border, 0, UDim.new(0, 13))
    
    local toggleCircle = CreateRoundedFrame(toggleBg, UDim2.new(0, 22, 0, 22), 
        UDim2.new(0, 2, 0.5, -11), Config.Theme.Text, 0, UDim.new(0, 11))
    
    local state = default or false
    
    local function updateToggle()
        if state then
            TweenObject(toggleBg, {BackgroundColor3 = Config.Theme.Primary}, 0.2)
            TweenObject(toggleCircle, {Position = UDim2.new(1, -24, 0.5, -11)}, 0.2)
        else
            TweenObject(toggleBg, {BackgroundColor3 = Config.Theme.Border}, 0.2)
            TweenObject(toggleCircle, {Position = UDim2.new(0, 2, 0.5, -11)}, 0.2)
        end
        if callback then callback(state) end
    end
    
    toggleBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            state = not state
            updateToggle()
        end
    end)
    
    updateToggle()
    table.insert(tab.Elements, frame)
    return {SetValue = function(value) state = value; updateToggle() end, GetValue = function() return state end}
end

function Menu:CreateSlider(tab, text, min, max, default, callback)
    local yPos = 10 + (#tab.Elements * 85)
    local frame = CreateRoundedFrame(tab.Content, UDim2.new(1, 0, 0, 65), 
        UDim2.new(0, 0, 0, yPos), Config.Theme.Surface, 0, UDim.new(0, 8))
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(1, -20, 0, 20)
    label.Position = UDim2.new(0, 10, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Config.Theme.Text
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Parent = frame
    valueLabel.Size = UDim2.new(0, 50, 0, 20)
    valueLabel.Position = UDim2.new(1, -60, 0, 5)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(default or min)
    valueLabel.TextColor3 = Config.Theme.Primary
    valueLabel.TextSize = 14
    valueLabel.Font = Enum.Font.GothamBold
    
    local sliderBg = CreateRoundedFrame(frame, UDim2.new(1, -20, 0, 4), 
        UDim2.new(0, 10, 0, 40), Config.Theme.Border, 0, UDim.new(0, 2))
    
    local sliderFill = CreateRoundedFrame(sliderBg, UDim2.new(0, 0, 1, 0), 
        UDim2.new(0, 0, 0, 0), Config.Theme.Primary, 0, UDim.new(0, 2))
    
    local sliderButton = CreateRoundedFrame(sliderBg, UDim2.new(0, 12, 0, 12), 
        UDim2.new(0, 0, 0.5, -6), Config.Theme.PrimaryHover, 0, UDim.new(0, 6))
    
    local value = default or min
    local dragging = false
    
    local function updateSlider(input)
        local relativeX = math.clamp((input.Position.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        value = min + (relativeX * (max - min))
        value = math.floor(value)
        valueLabel.Text = tostring(value)
        sliderFill.Size = UDim2.new(relativeX, 0, 1, 0)
        sliderButton.Position = UDim2.new(relativeX, -6, 0.5, -6)
        if callback then callback(value) end
    end
    
    sliderButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    updateSlider({Position = UDim2.new(0, (value - min) / (max - min) * sliderBg.AbsoluteSize.X + sliderBg.AbsolutePosition.X, 0, 0)})
    
    table.insert(tab.Elements, frame)
    return {SetValue = function(v) value = v; updateSlider({Position = UDim2.new(0, (value - min) / (max - min) * sliderBg.AbsoluteSize.X + sliderBg.AbsolutePosition.X, 0, 0)}) end, GetValue = function() return value end}
end

function Menu:CreateInput(tab, text, placeholder, callback)
    local yPos = 10 + (#tab.Elements * 70)
    local frame = CreateRoundedFrame(tab.Content, UDim2.new(1, 0, 0, 50), 
        UDim2.new(0, 0, 0, yPos), Config.Theme.Surface, 0, UDim.new(0, 8))
    
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0, 100, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Config.Theme.Text
    label.TextSize = 14
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    
    local inputBox = Instance.new("TextBox")
    inputBox.Parent = frame
    inputBox.Size = UDim2.new(0, 200, 0, 30)
    inputBox.Position = UDim2.new(1, -210, 0.5, -15)
    inputBox.BackgroundColor3 = Config.Theme.Background
    inputBox.Text = placeholder
    inputBox.TextColor3 = Config.Theme.TextSecondary
    inputBox.TextSize = 12
    inputBox.Font = Enum.Font.Gotham
    inputBox.PlaceholderText = placeholder
    
