function Menu:CreateTab(tabName)
    local tabButton = Instance.new("TextButton")
    tabButton.Parent = self.TabsContainer
    tabButton.Size = UDim2.new(1, -20, 0, 40)
    tabButton.Position = UDim2.new(0, 10, 0, 10 + (#self.Tabs * 45))
    tabButton.BackgroundColor3 = Config.Theme.Surface
    tabButton.BackgroundTransparency = 0.5
    tabButton.Text = tabName
    tabButton.TextColor3 = Config.Theme.TextSecondary
    tabButton.TextSize = 14
    tabButton.Font = Enum.Font.Gotham
    tabButton.BorderSizePixel = 0
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = tabButton
    
    local tabContent = Instance.new("Frame")
    tabContent.Parent = self.ContentContainer
    tabContent.Size = UDim2.new(1, -20, 1, -20)
    tabContent.Position = UDim2.new(0, 10, 0, 10)
    tabContent.BackgroundTransparency = 1
    tabContent.Visible = false
    
    local tab = {
        Name = tabName,
        Button = tabButton,
        Content = tabContent,
        Elements = {}
    }
    
    tabButton.MouseButton1Click:Connect(function()
        self:SelectTab(tab)
    end)
    
    table.insert(self.Tabs, tab)
    
    if #self.Tabs == 1 then
        self:SelectTab(tab)
    end
    
    return setmetatable({}, {
        __index = function(_, key)
            if key == "CreateButton" then
                return function(_, ...) return self:CreateButton(tab, ...) end
            elseif key == "CreateToggle" then
                return function(_, ...) return self:CreateToggle(tab, ...) end
            elseif key == "CreateSlider" then
                return function(_, ...) return self:CreateSlider(tab, ...) end
            elseif key == "CreateInput" then
                return function(_, ...) return self:CreateInput(tab, ...) end
            elseif key == "CreateDropdown" then
                return function(_, ...) return self:CreateDropdown(tab, ...) end
            end
        end
    })
end

function Menu:SelectTab(tab)
    if self.CurrentTab then
        TweenObject(self.CurrentTab.Button, {BackgroundTransparency = 0.5, TextColor3 = Config.Theme.TextSecondary}, 0.2)
        self.CurrentTab.Content.Visible = false
    end
    
    self.CurrentTab = tab
    TweenObject(tab.Button, {BackgroundTransparency = 0, TextColor3 = Config.Theme.Primary}, 0.2)
    tab.Content.Visible = true
end

